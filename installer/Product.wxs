<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" 
           Name="MSI Remote Agent" 
           Language="1033" 
           Version="1.0.0" 
           Manufacturer="Your Company" 
           UpgradeCode="12345678-1234-1234-1234-123456789012">
    
    <Package InstallerVersion="200" 
             Compressed="yes" 
             InstallScope="perMachine" 
             InstallPrivileges="elevated"
             Description="MSI Remote Agent Service"
             Comments="Remote monitoring and control agent" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Installation directory -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="MSI Remote Agent">
          <!-- Removed ServiceInstall and ServiceControl, using CustomAction instead -->
          <Component Id="AgentExecutable" Guid="87654321-4321-4321-4321-210987654321">
            <File Id="AgentExe" 
                  Source="..\agent\dist\msi-agent.exe" 
                  KeyPath="yes" 
                  Checksum="yes" />
          </Component>

          <!-- Configuration file -->
          <Component Id="ConfigFile" Guid="11111111-2222-3333-4444-555555555555">
            <File Id="ConfigJson" 
                  Source="..\installer\config.json" 
                  KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>

      <!-- Start Menu shortcut -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="MSI Remote Agent">
          <Component Id="ApplicationShortcut" Guid="22222222-3333-4444-5555-666666666666">
            <Shortcut Id="UninstallProduct"
                     Name="Uninstall MSI Remote Agent"
                     Target="[SystemFolder]msiexec.exe"
                     Arguments="/x [ProductCode]"
                     Description="Uninstalls MSI Remote Agent" />
            <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall"/>
            <RegistryValue Root="HKCU" 
                          Key="Software\MSIRemoteAgent" 
                          Name="installed" 
                          Type="integer" 
                          Value="1" 
                          KeyPath="yes"/>
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <!-- Features to install -->
    <Feature Id="ProductFeature" Title="MSI Remote Agent" Level="1">
      <ComponentRef Id="AgentExecutable" />
      <ComponentRef Id="ConfigFile" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <!-- Custom actions to install/uninstall Windows Service using sc command -->
    <CustomAction Id="InstallService" 
                  Directory="INSTALLFOLDER" 
                  ExeCommand="cmd.exe /c sc create MSIRemoteAgent binPath= &quot;[INSTALLFOLDER]msi-agent.exe&quot; start= auto DisplayName= &quot;MSI Remote Agent&quot; &amp;&amp; sc description MSIRemoteAgent &quot;Remote monitoring and control agent for MSI system&quot; &amp;&amp; sc start MSIRemoteAgent"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="UninstallService"
                  Directory="INSTALLFOLDER"
                  ExeCommand="cmd.exe /c sc stop MSIRemoteAgent &amp;&amp; sc delete MSIRemoteAgent"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Firewall rules -->
    <CustomAction Id="AddFirewallRule" 
                  Directory="INSTALLFOLDER" 
                  ExeCommand="netsh advfirewall firewall add rule name=&quot;MSI Remote Agent&quot; dir=in action=allow program=&quot;[INSTALLFOLDER]msi-agent.exe&quot; enable=yes"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="RemoveFirewallRule"
                  Directory="INSTALLFOLDER"
                  ExeCommand="netsh advfirewall firewall delete rule name=&quot;MSI Remote Agent&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Updated install sequence to use custom actions for service installation -->
    <InstallExecuteSequence>
      <Custom Action="InstallService" After="InstallFiles">NOT Installed</Custom>
      <Custom Action="AddFirewallRule" After="InstallService">NOT Installed</Custom>
      <Custom Action="UninstallService" Before="RemoveFiles">Installed AND NOT REINSTALL</Custom>
      <Custom Action="RemoveFirewallRule" Before="UninstallService">Installed AND NOT REINSTALL</Custom>
    </InstallExecuteSequence>

    <!-- UI -->
    <UIRef Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
  </Product>
</Wix>
