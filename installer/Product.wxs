<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" 
           Name="MSI Remote Agent" 
           Language="1033" 
           Version="1.0.0" 
           Manufacturer="Your Company" 
           UpgradeCode="12345678-1234-1234-1234-123456789012">
    
    <Package InstallerVersion="200" 
             Compressed="yes" 
             InstallScope="perMachine" 
             InstallPrivileges="elevated"
             Description="MSI Remote Agent Service"
             Comments="Remote monitoring and control agent" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Installation directory -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="MSI Remote Agent">
          <Component Id="AgentExecutable" Guid="87654321-4321-4321-4321-210987654321">
            <File Id="AgentExe" 
                  Source="..\agent\dist\agent.exe"
                  Name="agent.exe"
                  KeyPath="yes" 
                  Checksum="yes" />
          </Component>

          <Component Id="ConfigFile" Guid="11111111-2222-3333-4444-555555555555">
            <File Id="ConfigJson" 
                  Source="..\installer\config.json" 
                  KeyPath="yes" />
          </Component>

          <Component Id="ServiceInstaller" Guid="99999999-8888-7777-6666-555555555555">
            <File Id="InstallServiceCmd" 
                  Source="install-service.cmd" 
                  KeyPath="yes" />
            <File Id="UninstallServiceCmd" 
                  Source="uninstall-service.cmd" />
          </Component>
          
          <Component Id="ReadmeFile" Guid="AAAAAAAA-BBBB-CCCC-DDDD-EEEEEEEEEEEE">
            <File Id="ReadmeTxt" 
                  Source="README.txt" 
                  KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="MSI Remote Agent">
          <Component Id="ApplicationShortcut" Guid="22222222-3333-4444-5555-666666666666">
            <!-- Added elevated shortcut for service installation -->
            <Shortcut Id="InstallServiceShortcut"
                     Name="Install Service (Run as Admin)"
                     Target="[INSTALLFOLDER]install-service.cmd"
                     Arguments="&quot;[INSTALLFOLDER]&quot;"
                     Description="Install MSI Remote Agent Service - Must run as Administrator"
                     WorkingDirectory="INSTALLFOLDER" />
            <Shortcut Id="OpenInstallFolder"
                     Name="Open Installation Folder"
                     Target="[INSTALLFOLDER]"
                     Description="Open the MSI Remote Agent installation folder" />
            <Shortcut Id="UninstallProduct"
                     Name="Uninstall MSI Remote Agent"
                     Target="[SystemFolder]msiexec.exe"
                     Arguments="/x [ProductCode]"
                     Description="Uninstalls MSI Remote Agent" />
            <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall"/>
            <RegistryValue Root="HKCU" 
                          Key="Software\MSIRemoteAgent" 
                          Name="installed" 
                          Type="integer" 
                          Value="1" 
                          KeyPath="yes"/>
          </Component>
        </Directory>
      </Directory>
      
      <!-- Added desktop shortcut for easier access -->
      <Directory Id="DesktopFolder" Name="Desktop">
        <Component Id="DesktopShortcut" Guid="FFFFFFFF-EEEE-DDDD-CCCC-BBBBBBBBBBBB">
          <Shortcut Id="DesktopInstallServiceShortcut"
                   Name="Install MSI Agent Service"
                   Target="[INSTALLFOLDER]install-service.cmd"
                   Arguments="&quot;[INSTALLFOLDER]&quot;"
                   Description="Install MSI Remote Agent Service - Right-click and Run as Administrator"
                   WorkingDirectory="INSTALLFOLDER" />
          <RegistryValue Root="HKCU" 
                        Key="Software\MSIRemoteAgent" 
                        Name="desktop_shortcut" 
                        Type="integer" 
                        Value="1" 
                        KeyPath="yes"/>
        </Component>
      </Directory>
    </Directory>

    <Feature Id="ProductFeature" Title="MSI Remote Agent" Level="1">
      <ComponentRef Id="AgentExecutable" />
      <ComponentRef Id="ConfigFile" />
      <ComponentRef Id="ServiceInstaller" />
      <ComponentRef Id="ReadmeFile" />
      <ComponentRef Id="ApplicationShortcut" />
      <!-- Added desktop shortcut to feature -->
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- UI -->
    <UIRef Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
  </Product>
</Wix>
