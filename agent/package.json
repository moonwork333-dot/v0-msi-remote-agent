{
  "name": "msi-remote-agent",
  "version": "1.0.0",
  "description": "Windows agent for MSI Remote Administration",
  "main": "service.js",
  "bin": "service.js",
  "scripts": {
    "start": "node service.js",
    "build": "pkg service.js --targets node16-win-x64 --output dist/agent.exe"
  },
  "keywords": ["remote", "administration", "windows", "agent"],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.14.2",
    "screenshot-desktop": "^1.12.7",
    "robotjs": "^0.6.0",
    "node-windows": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "targets": ["node16-win-x64"],
    "outputPath": "dist"
  }
}
