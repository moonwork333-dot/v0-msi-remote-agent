{
  "name": "msi-remote-agent",
  "version": "1.0.0",
  "description": "Agent service for MSI Remote Agent system",
  "main": "service.js",
  "scripts": {
    "start": "node service.js",
    "dev": "node service.js",
    "build": "pkg . --targets node18-win-x64 --output dist/agent.exe",
    "install-service": "node install-service.js",
    "uninstall-service": "node uninstall-service.js"
  },
  "bin": "service.js",
  "pkg": {
    "assets": [
      "config.json",
      "input-control.js",
      "install-service.js",
      "uninstall-service.js",
      "node_modules/screenshot-desktop/**/*",
      "node_modules/node-windows/**/*"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "screenshot-desktop": "^1.15.0",
    "node-windows": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
